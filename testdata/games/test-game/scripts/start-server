#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

PORT="${GAME_PORT:-27015}"

# Failure injection via TEST_BEHAVIOR env var.
# Default (empty): normal happy-path behavior.
case "${TEST_BEHAVIOR}" in
  crash-after-ready)
    echo "Server is ready"
    sleep 3
    echo "[start-server] simulating crash"
    exit 1
    ;;
  crash-before-ready)
    echo "[start-server] starting..."
    sleep 1
    echo "[start-server] fatal error during startup"
    exit 1
    ;;
  ignore-sigterm)
    echo "Server is ready"
    trap '' TERM INT
    echo "[start-server] ignoring shutdown signals"
    while true; do sleep 1; done
    ;;
  slow-ready)
    DELAY="${READY_DELAY_SECONDS:-10}"
    echo "[start-server] loading world (${DELAY}s)..."
    sleep "$DELAY"
    echo "Server is ready"
    ;;
  exit-clean)
    echo "Server is ready"
    sleep 3
    echo "[start-server] shutting down cleanly"
    exit 0
    ;;
  stdout-flood)
    echo "Server is ready"
    while true; do
      dd if=/dev/urandom bs=4096 count=1 2>/dev/null | base64
    done
    ;;
esac

# Default path: normal behavior
echo "[start-server] starting test game on port $PORT"
echo "Server is ready"

cleanup() {
    echo "[start-server] received shutdown signal"
    exit 0
}
trap cleanup TERM INT

if command -v socat >/dev/null 2>&1; then
    socat TCP-LISTEN:"$PORT",reuseaddr,fork EXEC:"echo OK" &
    SOCAT_PID=$!
    wait $SOCAT_PID
else
    while true; do sleep 1; done
fi
