#!/bin/bash
RCON_PORT="${RCON_PORT:-28016}"
RCON_PASSWORD="${RCON_PASSWORD:-changeme}"

echo "[stop-server] announcing shutdown"
rcon -a "localhost:${RCON_PORT}" -p "$RCON_PASSWORD" "say Server shutting down in 5 seconds..." 2>/dev/null || true
sleep 5
rcon -a "localhost:${RCON_PORT}" -p "$RCON_PASSWORD" "server.save" 2>/dev/null || true
sleep 2
echo "[stop-server] save complete, ready for shutdown"
