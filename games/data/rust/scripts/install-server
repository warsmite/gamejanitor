#!/bin/bash
set -e

echo "[install-server] downloading Rust dedicated server via SteamCMD (app 258550)"
steamcmd-retry \
    +force_install_dir /data/server \
    +login anonymous \
    +app_update 258550 validate \
    +quit

echo "[install-server] Rust dedicated server installed"

MOD_FRAMEWORK="${MOD_FRAMEWORK:-none}"

install_oxide() {
    echo "[install-server] fetching latest Oxide.Rust release from GitHub"
    RELEASE_JSON=$(curl -fsSL "https://api.github.com/repos/OxideMod/Oxide.Rust/releases/latest")

    ASSET_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name == "Oxide.Rust-linux.zip") | .browser_download_url')
    TAG=$(echo "$RELEASE_JSON" | jq -r '.tag_name')

    if [ -z "$ASSET_URL" ] || [ "$ASSET_URL" = "null" ]; then
        echo "[install-server] ERROR: could not find Oxide.Rust-linux.zip in latest release"
        exit 1
    fi

    echo "[install-server] downloading Oxide.Rust $TAG"
    curl -fsSL -o /tmp/oxide.zip -L "$ASSET_URL"

    echo "[install-server] extracting Oxide into server directory"
    unzip -qo /tmp/oxide.zip -d /data/server/
    rm -f /tmp/oxide.zip

    echo "[install-server] Oxide.Rust $TAG installed"
}

install_carbon() {
    echo "[install-server] fetching latest Carbon release from GitHub"
    RELEASE_JSON=$(curl -fsSL "https://api.github.com/repos/CarbonCommunity/Carbon/releases/latest")

    ASSET_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name == "Carbon.Linux.Release.tar.gz") | .browser_download_url')
    TAG=$(echo "$RELEASE_JSON" | jq -r '.tag_name')

    if [ -z "$ASSET_URL" ] || [ "$ASSET_URL" = "null" ]; then
        echo "[install-server] ERROR: could not find Carbon.Linux.Release.tar.gz in latest release"
        exit 1
    fi

    echo "[install-server] downloading Carbon $TAG"
    curl -fsSL -o /tmp/carbon.tar.gz -L "$ASSET_URL"

    echo "[install-server] extracting Carbon into server directory"
    tar -xzf /tmp/carbon.tar.gz -C /data/server/
    rm -f /tmp/carbon.tar.gz

    echo "[install-server] Carbon $TAG installed"
}

remove_frameworks() {
    if [ -d "/data/server/oxide" ] || ls /data/server/RustDedicated_Data/Managed/Oxide.*.dll >/dev/null 2>&1; then
        echo "[install-server] removing Oxide files"
        rm -rf /data/server/oxide
        rm -f /data/server/RustDedicated_Data/Managed/Oxide.*.dll
    fi
    if [ -d "/data/server/carbon" ] || [ -f "/data/server/doorstop_config.ini" ]; then
        echo "[install-server] removing Carbon files"
        rm -rf /data/server/carbon
        rm -f /data/server/doorstop_config.ini
        rm -f /data/server/RustDedicated_Data/Managed/Carbon.*.dll
    fi
}

case "$MOD_FRAMEWORK" in
    oxide)
        remove_frameworks
        install_oxide
        ;;
    carbon)
        remove_frameworks
        install_carbon
        ;;
    *)
        remove_frameworks
        ;;
esac
