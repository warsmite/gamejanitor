#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Steam SDK setup (required for Steam networking)
mkdir -p ~/.steam/sdk32 ~/.steam/sdk64
SC64=$(find /data/server -name "steamclient.so" -path "*/linux64/*" 2>/dev/null | head -1)
[ -z "$SC64" ] && SC64=/usr/lib/steam/sdk64/steamclient.so
[ -f "$SC64" ] && ln -sf "$SC64" ~/.steam/sdk64/steamclient.so
SC32=$(find /data/server -name "steamclient.so" -path "*/linux32/*" 2>/dev/null | head -1)
[ -z "$SC32" ] && SC32=/usr/lib/steam/sdk32/steamclient.so
[ -f "$SC32" ] && ln -sf "$SC32" ~/.steam/sdk32/steamclient.so

cd /data/server

# Write server config if it doesn't exist
ZOMBOID_DIR="/data/Zomboid"
CONFIG_DIR="$ZOMBOID_DIR/Server"
CONFIG_FILE="$CONFIG_DIR/servertest.ini"

mkdir -p "$CONFIG_DIR"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "[start-server] generating initial server config"
    cat > "$CONFIG_FILE" <<EOF
PublicName=${SERVER_NAME:-Gamejanitor PZ Server}
PublicDescription=
MaxPlayers=${MAX_PLAYERS:-16}
Open=${PUBLIC:-true}
Password=${SERVER_PASSWORD:-}
DefaultPort=${GAME_PORT:-16261}
Map=${MAP:-Muldraugh, KY}
Mods=${MOD_IDS:-}
WorkshopItems=${MOD_IDS:-}
EOF
fi

# Use the JRE bundled in the depot — PZ requires a specific Java version
JAVA="/data/server/jre64/bin/java"
if [ ! -x "$JAVA" ]; then
    echo "[start-server] ERROR: bundled JRE not found at $JAVA"
    exit 1
fi

echo "[start-server] launching Project Zomboid dedicated server (java: $JAVA)"

# JVM heap at 85% of container limit — leaves room for native memory (metaspace, threads, GC)
HEAP=$((${MEMORY_LIMIT_MB:-4096} * 85 / 100))
echo "[start-server] JVM heap: ${HEAP}m (from ${MEMORY_LIMIT_MB:-4096}m limit)"

# Launch PZ directly, bypassing start-server.sh which requires the `file` command
# for Java detection. This mirrors what start-server.sh does internally.
export LD_LIBRARY_PATH="/data/server/linux64:/data/server/natives:${LD_LIBRARY_PATH}"

exec run-gameserver "$JAVA" \
    -Djava.awt.headless=true \
    -Dzomboid.steam=1 \
    -Dzomboid.znetlog=1 \
    -XX:+UseZGC \
    -XX:-CreateCoredumpOnCrash \
    -XX:-OmitStackTraceInFastThrow \
    -Xms${HEAP}m \
    -Xmx${HEAP}m \
    -cp java/:java/*:pzexe.jar \
    -Djava.library.path=natives/linux64:natives/:linux64/ \
    zombie.network.GameServer \
    -statistic 0 \
    -cachedir="$ZOMBOID_DIR" \
    -adminpassword "${ADMIN_PASSWORD:-changeme}" \
    -servername servertest \
    -port "${GAME_PORT:-16261}"
