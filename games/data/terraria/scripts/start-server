#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

WORLD_NAME="${WORLD_NAME:-Gamejanitor}"
MAX_PLAYERS="${MAX_PLAYERS:-8}"
PASSWORD="${PASSWORD:-}"
DIFFICULTY="${DIFFICULTY:-1}"
WORLD_SIZE="${WORLD_SIZE:-2}"
GAME_PORT="${GAME_PORT:-7777}"
QUERY_PORT="${QUERY_PORT:-7878}"

WORLD_DIR="/data/worlds"
mkdir -p "$WORLD_DIR"
WORLD_FILE="${WORLD_DIR}/${WORLD_NAME}.wld"

# TShock config/db stored in persistent volume
mkdir -p /data/tshock

echo "[start-server] REST API enabled on port ${QUERY_PORT}"

echo "[start-server] config: world=${WORLD_NAME} size=${WORLD_SIZE} difficulty=${DIFFICULTY}"
echo "[start-server] config: maxplayers=${MAX_PLAYERS} port=${GAME_PORT}"

# FIFO pipe for command input
FIFO=/tmp/cmd-input
mkfifo "$FIFO" 2>/dev/null || true

ARGS=(
    -world "$WORLD_FILE"
    -autocreate "$WORLD_SIZE"
    -difficulty "$DIFFICULTY"
    -maxplayers "$MAX_PLAYERS"
    -port "$GAME_PORT"
    -configpath /data/tshock
    -rest-enabled true
    -rest-port "$QUERY_PORT"
    -secure
    -lang "en-US"
)

if [ -n "$PASSWORD" ]; then
    ARGS+=(-password "$PASSWORD")
fi

# .NET needs a writable extraction dir (required for process runtime / bwrap)
export DOTNET_BUNDLE_EXTRACT_BASE_DIR="${DOTNET_BUNDLE_EXTRACT_BASE_DIR:-/tmp/.dotnet}"

echo "[start-server] starting TShock server"
/data/TShock.Server "${ARGS[@]}" < <(tail -f "$FIFO") &
SERVER_PID=$!
trap "kill $SERVER_PID 2>/dev/null" TERM INT
wait $SERVER_PID
EXIT_CODE=$?
kill 0 2>/dev/null
exit $EXIT_CODE
