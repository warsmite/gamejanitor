#!/bin/bash
set -e

if [ -d "/depot" ]; then
    echo "[install-server] copying pre-downloaded game files from depot cache"
    mkdir -p /data/server
    cp -a /depot/. /data/server/
    echo "[install-server] Garry's Mod dedicated server installed from depot"
else
    echo "[install-server] downloading Garry's Mod dedicated server via SteamCMD (app 4020)"
    steamcmd-retry \
        +force_install_dir /data/server \
        +login anonymous \
        +app_update 4020 validate \
        +quit
    echo "[install-server] Garry's Mod dedicated server installed"
fi
