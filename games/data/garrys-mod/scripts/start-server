#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Steam SDK setup (required for Steam networking)
mkdir -p ~/.steam/sdk32 ~/.steam/sdk64
SC64=$(find /data/server -name "steamclient.so" -path "*/linux64/*" 2>/dev/null | head -1)
[ -z "$SC64" ] && SC64=/usr/lib/steam/sdk64/steamclient.so
[ -f "$SC64" ] && ln -sf "$SC64" ~/.steam/sdk64/steamclient.so
SC32=$(find /data/server -name "steamclient.so" -path "*/linux32/*" 2>/dev/null | head -1)
[ -z "$SC32" ] && SC32=/usr/lib/steam/sdk32/steamclient.so
[ -f "$SC32" ] && ln -sf "$SC32" ~/.steam/sdk32/steamclient.so

GAME_PORT="${GAME_PORT:-27015}"
RCON_PASSWORD="${RCON_PASSWORD:-changeme}"
HOSTNAME="${HOSTNAME:-Gamejanitor GMod Server}"
MAXPLAYERS="${MAXPLAYERS:-16}"
GAMEMODE="${GAMEMODE:-sandbox}"
MAP="${MAP:-gm_flatgrass}"

echo "[start-server] config: hostname=${HOSTNAME} maxplayers=${MAXPLAYERS}"
echo "[start-server] config: gamemode=${GAMEMODE} map=${MAP} port=${GAME_PORT}"

export LD_LIBRARY_PATH="/data/server/bin:${LD_LIBRARY_PATH}"

# Ensure rcon_password is set in server.cfg (CLI arg doesn't always take effect)
CFG_DIR="/data/server/garrysmod/cfg"
mkdir -p "$CFG_DIR"
CFG_FILE="${CFG_DIR}/server.cfg"
touch "$CFG_FILE"
if grep -q '^rcon_password' "$CFG_FILE" 2>/dev/null; then
    sed -i "s|^rcon_password.*|rcon_password \"${RCON_PASSWORD}\"|" "$CFG_FILE"
else
    echo "rcon_password \"${RCON_PASSWORD}\"" >> "$CFG_FILE"
fi

CONSOLE_LOG="/data/server/garrysmod/console.log"
rm -f "$CONSOLE_LOG"

echo "[start-server] starting Garry's Mod dedicated server"
cd /data/server

# Workshop collection — GMod engine downloads all addons at boot
WORKSHOP_ARG=""
if [ -n "$WORKSHOP_COLLECTION" ]; then
    WORKSHOP_ARG="+host_workshop_collection $WORKSHOP_COLLECTION"
    echo "[start-server] workshop collection: $WORKSHOP_COLLECTION"
fi

# srcds_linux doesn't write to stdout on Linux, -condebug writes to console.log
# Tail console.log to stdout in background so Docker captures it
(while [ ! -f "$CONSOLE_LOG" ]; do sleep 0.5; done; tail -f -n +1 "$CONSOLE_LOG") &

./srcds_linux -game garrysmod \
    -ip 0.0.0.0 \
    -port "$GAME_PORT" \
    -norestart \
    -condebug \
    +maxplayers "$MAXPLAYERS" \
    +hostname "$HOSTNAME" \
    +gamemode "$GAMEMODE" \
    +map "$MAP" \
    +rcon_password "$RCON_PASSWORD" \
    $WORKSHOP_ARG &
SERVER_PID=$!
trap "kill $SERVER_PID 2>/dev/null" TERM INT
wait $SERVER_PID
EXIT_CODE=$?
kill 0 2>/dev/null
exit $EXIT_CODE
