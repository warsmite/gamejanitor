#!/bin/bash
set -e

if [ -d "/depot" ]; then
    echo "[install-server] copying pre-downloaded game files from depot cache"
    mkdir -p /data/server
    cp -a /depot/. /data/server/
    echo "[install-server] Palworld dedicated server installed from depot"
else
    echo "[install-server] downloading Palworld dedicated server via SteamCMD (app 2394010)"
    steamcmd-retry \
        +force_install_dir /data/server \
        +login anonymous \
        +app_update 2394010 validate \
        +quit
    echo "[install-server] Palworld dedicated server installed"
fi
