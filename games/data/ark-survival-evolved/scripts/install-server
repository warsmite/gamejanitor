#!/bin/bash
set -e

echo "[install-server] downloading ARK dedicated server via SteamCMD (app 376030)"
steamcmd-retry \
    +force_install_dir /data/server \
    +login anonymous \
    +app_update 376030 validate \
    +quit

# Download workshop mods if configured (ARK mods can be very large, do at install time)
/scripts/install-workshop-mods 346110

echo "[install-server] ARK dedicated server installed"
