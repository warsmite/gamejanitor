#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Steam SDK setup (required for Steam networking)
mkdir -p ~/.steam/sdk32 ~/.steam/sdk64
SC64=$(find /data/server -name "steamclient.so" -path "*/linux64/*" 2>/dev/null | head -1)
[ -z "$SC64" ] && SC64=/usr/lib/steam/sdk64/steamclient.so
[ -f "$SC64" ] && ln -sf "$SC64" ~/.steam/sdk64/steamclient.so
SC32=$(find /data/server -name "steamclient.so" -path "*/linux32/*" 2>/dev/null | head -1)
[ -z "$SC32" ] && SC32=/usr/lib/steam/sdk32/steamclient.so
[ -f "$SC32" ] && ln -sf "$SC32" ~/.steam/sdk32/steamclient.so

SESSION_NAME="${SESSION_NAME:-Gamejanitor ARK Server}"
MAX_PLAYERS="${MAX_PLAYERS:-70}"
ADMIN_PASSWORD="${ADMIN_PASSWORD:-changeme}"
SERVER_PASSWORD="${SERVER_PASSWORD:-}"
MAP="${MAP:-TheIsland}"
GAME_PORT="${GAME_PORT:-7777}"
QUERY_PORT="${QUERY_PORT:-27015}"
RCON_PORT="${RCON_PORT:-27020}"

echo "[start-server] config: session=${SESSION_NAME} map=${MAP} maxplayers=${MAX_PLAYERS}"
echo "[start-server] config: game_port=${GAME_PORT} query_port=${QUERY_PORT} rcon_port=${RCON_PORT}"

# ARK saves and config live under ShooterGame/Saved/
# Symlink to /data/saves so everything persists on the instance volume
SAVE_DIR="/data/server/ShooterGame/Saved"
mkdir -p /data/saves
mkdir -p "$(dirname "$SAVE_DIR")"
# Remove real directory if it exists from install, then symlink
if [ -d "$SAVE_DIR" ] && [ ! -L "$SAVE_DIR" ]; then
    rm -rf "$SAVE_DIR"
fi
ln -sfn /data/saves "$SAVE_DIR"

# Detect installed Workshop mods by scanning the mods directory.
# Each mod is a subdirectory named by its Workshop ID (e.g. 731604991/).
MODS_DIR="/data/server/ShooterGame/Content/Mods"
MOD_IDS=""
if [ -d "$MODS_DIR" ]; then
    for dir in "$MODS_DIR"/*/; do
        [ -d "$dir" ] || continue
        mod_id=$(basename "$dir")
        # Only include numeric directory names (Workshop IDs)
        if [[ "$mod_id" =~ ^[0-9]+$ ]]; then
            if [ -n "$MOD_IDS" ]; then
                MOD_IDS="${MOD_IDS},${mod_id}"
            else
                MOD_IDS="$mod_id"
            fi
        fi
    done
fi

# Write ActiveMods to GameUserSettings.ini
CONFIG_DIR="/data/saves/Config/LinuxServer"
mkdir -p "$CONFIG_DIR"
INI_FILE="${CONFIG_DIR}/GameUserSettings.ini"
touch "$INI_FILE"

if [ -n "$MOD_IDS" ]; then
    echo "[start-server] active mods: $MOD_IDS"
    # Update or add ActiveMods in [ServerSettings]
    if grep -q '^ActiveMods=' "$INI_FILE" 2>/dev/null; then
        sed -i "s|^ActiveMods=.*|ActiveMods=${MOD_IDS}|" "$INI_FILE"
    else
        # Ensure [ServerSettings] section exists
        if ! grep -q '^\[ServerSettings\]' "$INI_FILE" 2>/dev/null; then
            echo -e "\n[ServerSettings]" >> "$INI_FILE"
        fi
        sed -i "/^\[ServerSettings\]/a ActiveMods=${MOD_IDS}" "$INI_FILE"
    fi
else
    # No mods — clear ActiveMods if it exists
    sed -i '/^ActiveMods=/d' "$INI_FILE" 2>/dev/null || true
fi

PASSWORD_PARAM=""
if [ -n "$SERVER_PASSWORD" ]; then
    PASSWORD_PARAM="?ServerPassword=${SERVER_PASSWORD}"
fi

echo "[start-server] starting ARK dedicated server"
cd /data/server
exec run-gameserver ./ShooterGame/Binaries/Linux/ShooterGameServer \
    "${MAP}?listen?SessionName=${SESSION_NAME}?ServerAdminPassword=${ADMIN_PASSWORD}${PASSWORD_PARAM}?Port=${GAME_PORT}?QueryPort=${QUERY_PORT}?RCONPort=${RCON_PORT}?RCONEnabled=True?MaxPlayers=${MAX_PLAYERS}" \
    -server \
    -log \
    -automanagedmods \
    $([ "${ENABLE_BATTLEYE:-false}" = "true" ] || echo "-NoBattlEye")
