#!/bin/bash
RCON_PORT="${RCON_PORT:-27020}"
RCON_PASSWORD="${ADMIN_PASSWORD:-changeme}"

echo "[stop-server] announcing shutdown"
rcon -a "localhost:${RCON_PORT}" -p "$RCON_PASSWORD" "ServerChat Server shutting down in 5 seconds..." 2>/dev/null || true
sleep 5
rcon -a "localhost:${RCON_PORT}" -p "$RCON_PASSWORD" "SaveWorld" 2>/dev/null || true
sleep 3
echo "[stop-server] save complete, ready for shutdown"
