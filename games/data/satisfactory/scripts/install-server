#!/bin/bash
set -e

if [ -d "/depot" ]; then
    echo "[install-server] copying pre-downloaded game files from depot cache"
    mkdir -p /data/server
    cp -a /depot/. /data/server/
    echo "[install-server] Satisfactory dedicated server installed from depot"
else
    echo "[install-server] downloading Satisfactory dedicated server via SteamCMD (app 1690800)"
    steamcmd-retry \
        +force_install_dir /data/server \
        +login anonymous \
        +app_update 1690800 -beta public validate \
        +quit
    echo "[install-server] Satisfactory dedicated server installed"
fi
