#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Write eula.txt from env var
echo "eula=${EULA:-false}" > /data/eula.txt

# Update only env-managed keys in server.properties, preserve everything else
update_property() {
    local key="$1" value="$2" file="$3"
    if grep -q "^${key}=" "$file" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    else
        echo "${key}=${value}" >> "$file"
    fi
}

PROPS=/data/server.properties
update_property "server-port"  "${SERVER_PORT:-25565}"           "$PROPS"
update_property "gamemode"     "${GAMEMODE:-survival}"            "$PROPS"
update_property "max-players"  "${MAX_PLAYERS:-20}"               "$PROPS"
update_property "difficulty"   "${DIFFICULTY:-normal}"             "$PROPS"
update_property "motd"         "${MOTD:-A Gamejanitor Server}"    "$PROPS"
update_property "pvp"          "${PVP:-true}"                     "$PROPS"
update_property "hardcore"     "${HARDCORE:-false}"                 "$PROPS"
update_property "allow-flight" "${ALLOW_FLIGHT:-false}"             "$PROPS"
update_property "spawn-protection" "${SPAWN_PROTECTION:-16}"        "$PROPS"
update_property "online-mode"  "${ONLINE_MODE:-true}"               "$PROPS"
update_property "white-list"   "${WHITELIST:-false}"                "$PROPS"
update_property "player-idle-timeout" "${PLAYER_IDLE_TIMEOUT:-0}"   "$PROPS"
update_property "level-seed"   "${SEED}"                            "$PROPS"
update_property "level-name"   "${LEVEL_NAME:-world}"               "$PROPS"
update_property "generate-structures" "${GENERATE_STRUCTURES:-true}" "$PROPS"
update_property "max-world-size" "${MAX_WORLD_SIZE:-29999984}"      "$PROPS"
update_property "view-distance" "${VIEW_DISTANCE:-10}"              "$PROPS"
update_property "simulation-distance" "${SIMULATION_DISTANCE:-10}"  "$PROPS"
update_property "resource-pack" "${RESOURCE_PACK}"                  "$PROPS"
update_property "require-resource-pack" "${REQUIRE_RESOURCE_PACK:-false}" "$PROPS"
update_property "enable-rcon"  "true"                              "$PROPS"
update_property "rcon.port"    "${RCON_PORT:-25575}"               "$PROPS"
update_property "rcon.password" "${RCON_PASSWORD}"                 "$PROPS"

echo "[start-server] config: gamemode=${GAMEMODE:-survival} difficulty=${DIFFICULTY:-normal} max_players=${MAX_PLAYERS:-20} port=${SERVER_PORT:-25565}"
echo "[start-server] updated server.properties and eula.txt"

# Java version is resolved by the controller via image variants —
# this container has exactly one JDK on the PATH.
JAVA_BIN="java"
echo "[start-server] using $(java -version 2>&1 | head -1)"

# Calculate JVM heap from MEMORY_LIMIT_MB (leave ~15% for GC overhead)
MEMORY_LIMIT_MB="${MEMORY_LIMIT_MB:-1024}"
HEAP=$(( MEMORY_LIMIT_MB * 85 / 100 ))
if [ "$HEAP" -lt 256 ]; then
    HEAP=256
fi
echo "[start-server] JVM heap: ${HEAP}m (from ${MEMORY_LIMIT_MB}m limit)"

# FIFO pipe for command input
FIFO=/tmp/cmd-input
mkfifo "$FIFO" 2>/dev/null || true

MODLOADER="${MODLOADER:-vanilla}"

# Aikar's optimized G1GC flags — industry standard for Minecraft servers.
# Tuned for Minecraft's high short-lived object allocation pattern.
# https://docs.papermc.io/paper/aikars-flags
AIKAR_FLAGS=(
    -XX:+UseG1GC
    -XX:+ParallelRefProcEnabled
    -XX:MaxGCPauseMillis=200
    -XX:+UnlockExperimentalVMOptions
    -XX:+DisableExplicitGC
    -XX:+AlwaysPreTouch
    -XX:G1NewSizePercent=30
    -XX:G1MaxNewSizePercent=40
    -XX:G1HeapRegionSize=8M
    -XX:G1ReservePercent=20
    -XX:G1HeapWastePercent=5
    -XX:G1MixedGCCountTarget=4
    -XX:InitiatingHeapOccupancyPercent=15
    -XX:G1MixedGCLiveThresholdPercent=90
    -XX:G1RSetUpdatingPauseTimePercent=5
    -XX:SurvivorRatio=32
    -XX:+PerfDisableSharedMem
    -XX:MaxTenuringThreshold=1
)

# Determine which jar to launch
case "$MODLOADER" in
    fabric)
        SERVER_JAR="/data/fabric-server-launcher.jar"
        ;;
    forge)
        # Modern Forge uses @unix_args.txt with classpath-based launch (no -jar)
        FORGE_ARGS=$(find /data/libraries -name "unix_args.txt" 2>/dev/null | head -1)
        if [ -n "$FORGE_ARGS" ]; then
            # Write heap + Aikar's flags into user_jvm_args.txt (Forge reads this via @user_jvm_args.txt)
            {
                echo "-Xmx${HEAP}m"
                echo "-Xms${HEAP}m"
                printf '%s\n' "${AIKAR_FLAGS[@]}"
            } > /data/user_jvm_args.txt
            echo "[start-server] starting Forge server (modloader=forge, args=$FORGE_ARGS)"
            cd /data
            exec "$JAVA_BIN" @user_jvm_args.txt @"$FORGE_ARGS" nogui < <(tail -f "$FIFO")
        fi
        # Fallback for older Forge versions
        SERVER_JAR=$(find /data -maxdepth 1 -name "forge-*.jar" ! -name "*-installer.jar" ! -name "*-shim.jar" | head -1)
        if [ -z "$SERVER_JAR" ]; then
            SERVER_JAR="/data/server.jar"
        fi
        ;;
    *)
        SERVER_JAR="/data/server.jar"
        ;;
esac

echo "[start-server] starting Minecraft server (modloader=$MODLOADER, jar=$SERVER_JAR)"
exec "$JAVA_BIN" -Xmx${HEAP}m -Xms${HEAP}m "${AIKAR_FLAGS[@]}" -jar "$SERVER_JAR" nogui < <(tail -f "$FIFO")
