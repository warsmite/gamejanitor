#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Steam SDK setup (required for Steam networking)
mkdir -p ~/.steam/sdk32 ~/.steam/sdk64
SC64=$(find /data/server -name "steamclient.so" -path "*/linux64/*" 2>/dev/null | head -1)
[ -z "$SC64" ] && SC64=/usr/lib/steam/sdk64/steamclient.so
[ -f "$SC64" ] && ln -sf "$SC64" ~/.steam/sdk64/steamclient.so
SC32=$(find /data/server -name "steamclient.so" -path "*/linux32/*" 2>/dev/null | head -1)
[ -z "$SC32" ] && SC32=/usr/lib/steam/sdk32/steamclient.so
[ -f "$SC32" ] && ln -sf "$SC32" ~/.steam/sdk32/steamclient.so

SERVER_NAME="${SERVER_NAME:-Gamejanitor Valheim Server}"
WORLD_NAME="${WORLD_NAME:-Gamejanitor}"
SERVER_PASSWORD="${SERVER_PASSWORD:-changeme}"
GAME_PORT="${GAME_PORT:-2456}"

echo "[start-server] config: name=${SERVER_NAME} world=${WORLD_NAME} port=${GAME_PORT}"

# Valheim stores worlds under ~/.config/unity3d/IronGate/Valheim/worlds_local
# Symlink to /data/worlds so saves persist on the Docker volume
SAVE_DIR="${HOME}/.config/unity3d/IronGate/Valheim/worlds_local"
mkdir -p /data/worlds
mkdir -p "$(dirname "$SAVE_DIR")"
ln -sfn /data/worlds "$SAVE_DIR"

export LD_LIBRARY_PATH="/data/server/linux64:${LD_LIBRARY_PATH}"
export SteamAppId=892970

echo "[start-server] starting Valheim dedicated server"
cd /data/server
exec ./valheim_server.x86_64 \
    -name "$SERVER_NAME" \
    -port "$GAME_PORT" \
    -world "$WORLD_NAME" \
    -password "$SERVER_PASSWORD" \
    -nographics \
    -batchmode \
    -public "${PUBLIC_SERVER:-1}"
