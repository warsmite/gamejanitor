#!/bin/bash
set -e

if [ -d "/depot" ]; then
    echo "[install-server] copying pre-downloaded game files from depot cache"
    mkdir -p /data/server
    cp -a /depot/. /data/server/
    echo "[install-server] Valheim dedicated server installed from depot"
else
    echo "[install-server] downloading Valheim dedicated server via SteamCMD (app 896660)"
    steamcmd-retry \
        +force_install_dir /data/server \
        +login anonymous \
        +app_update 896660 validate \
        +quit
    echo "[install-server] Valheim dedicated server installed"
fi
