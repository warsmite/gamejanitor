#!/bin/bash
set -e

# Console log — persisted on the volume for log history across restarts
LOG_DIR=/data/.gamejanitor/logs
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/console.log") 2>&1

# Steam SDK setup (required for Steam networking)
mkdir -p ~/.steam/sdk32 ~/.steam/sdk64
SC64=$(find /data/server -name "steamclient.so" -path "*/linux64/*" 2>/dev/null | head -1)
[ -z "$SC64" ] && SC64=/usr/lib/steam/sdk64/steamclient.so
[ -f "$SC64" ] && ln -sf "$SC64" ~/.steam/sdk64/steamclient.so
SC32=$(find /data/server -name "steamclient.so" -path "*/linux32/*" 2>/dev/null | head -1)
[ -z "$SC32" ] && SC32=/usr/lib/steam/sdk32/steamclient.so
[ -f "$SC32" ] && ln -sf "$SC32" ~/.steam/sdk32/steamclient.so

HOSTNAME="${HOSTNAME:-Gamejanitor CS2 Server}"
MAXPLAYERS="${MAXPLAYERS:-16}"
RCON_PASSWORD="${RCON_PASSWORD:-changeme}"
GAME_TYPE="${GAME_TYPE:-0}"
GAME_MODE="${GAME_MODE:-1}"
MAP="${MAP:-de_dust2}"
GAME_PORT="${GAME_PORT:-27015}"
GSLT="${GSLT:-}"

echo "[start-server] config: hostname=${HOSTNAME} maxplayers=${MAXPLAYERS}"
echo "[start-server] config: game_type=${GAME_TYPE} game_mode=${GAME_MODE} map=${MAP} port=${GAME_PORT}"
echo "[start-server] config: gslt=${GSLT:+set}${GSLT:-not set}"

# CS2 needs engine libs on LD_LIBRARY_PATH (libv8.so etc.)
export LD_LIBRARY_PATH="/data/server/game/bin/linuxsteamrt64:${LD_LIBRARY_PATH}"

cd /data/server

GSLT_ARG=""
if [ -n "$GSLT" ]; then
    GSLT_ARG="+sv_setsteamaccount $GSLT"
fi

# Download workshop mods if configured
/scripts/install-workshop-mods 730

echo "[start-server] starting CS2 dedicated server"
exec ./game/bin/linuxsteamrt64/cs2 -dedicated \
    -port "$GAME_PORT" \
    +hostname "$HOSTNAME" \
    +game_type "$GAME_TYPE" \
    +game_mode "$GAME_MODE" \
    +mapgroup mg_active \
    +map "$MAP" \
    +rcon_password "$RCON_PASSWORD" \
    -maxplayers "$MAXPLAYERS" \
    $GSLT_ARG
