#!/bin/bash
set -e

if [ -d "/depot" ]; then
    echo "[install-server] copying pre-downloaded game files from depot cache"
    mkdir -p /data/server
    cp -a /depot/. /data/server/
    echo "[install-server] CS2 dedicated server installed from depot"
else
    echo "[install-server] downloading CS2 dedicated server via SteamCMD (app 730)"
    steamcmd-retry \
        +force_install_dir /data/server \
        +login anonymous \
        +app_update 730 validate \
        +quit
    echo "[install-server] CS2 dedicated server installed"
fi
