#!/bin/bash
set -e

# Update only env-managed keys in server.properties, preserve everything else
update_property() {
    local key="$1" value="$2" file="$3"
    if grep -q "^${key}=" "$file" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    else
        echo "${key}=${value}" >> "$file"
    fi
}

PROPS=/data/server/server.properties
update_property "server-name"      "${SERVER_NAME:-Gamejanitor Bedrock Server}" "$PROPS"
update_property "server-port"      "${SERVER_PORT:-19132}"                      "$PROPS"
update_property "server-portv6"   "${SERVER_PORT:-19132}"                      "$PROPS"
update_property "gamemode"         "${GAMEMODE:-survival}"                      "$PROPS"
update_property "difficulty"       "${DIFFICULTY:-normal}"                      "$PROPS"
update_property "max-players"      "${MAX_PLAYERS:-10}"                         "$PROPS"
update_property "level-name"       "${LEVEL_NAME:-Gamejanitor}"                 "$PROPS"
update_property "online-mode"      "${ONLINE_MODE:-true}"                       "$PROPS"
update_property "allow-cheats"     "${ALLOW_CHEATS:-false}"                     "$PROPS"
update_property "view-distance"    "${VIEW_DISTANCE:-32}"                       "$PROPS"

echo "[start-server] config: gamemode=${GAMEMODE:-survival} difficulty=${DIFFICULTY:-normal} max_players=${MAX_PLAYERS:-10} port=${SERVER_PORT:-19132}"
echo "[start-server] updated server.properties"

# FIFO pipe for command input
FIFO=/tmp/cmd-input
mkfifo "$FIFO" 2>/dev/null || true

export LD_LIBRARY_PATH=/data/server
cd /data/server

echo "[start-server] starting Bedrock server"
exec ./bedrock_server < <(tail -f "$FIFO")
