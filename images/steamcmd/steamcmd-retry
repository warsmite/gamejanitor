#!/bin/bash
# Wraps steamcmd.sh with retry on transient failures (e.g. "Missing configuration")
MAX_ATTEMPTS=5
DELAY=10

for attempt in $(seq 1 $MAX_ATTEMPTS); do
    if steamcmd.sh "$@"; then
        exit 0
    fi
    if [ $attempt -lt $MAX_ATTEMPTS ]; then
        echo "[steamcmd-retry] attempt $attempt/$MAX_ATTEMPTS failed, retrying in ${DELAY}s..."
        sleep $DELAY
    fi
done

echo "[steamcmd-retry] all $MAX_ATTEMPTS attempts failed"
exit 1
