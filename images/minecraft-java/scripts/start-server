#!/bin/bash
set -e

# Write eula.txt from env var
echo "eula=${EULA:-false}" > /data/eula.txt

# Update only env-managed keys in server.properties, preserve everything else
update_property() {
    local key="$1" value="$2" file="$3"
    if grep -q "^${key}=" "$file" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    else
        echo "${key}=${value}" >> "$file"
    fi
}

PROPS=/data/server.properties
update_property "server-port"  "${SERVER_PORT:-25565}"           "$PROPS"
update_property "gamemode"     "${GAMEMODE:-survival}"            "$PROPS"
update_property "max-players"  "${MAX_PLAYERS:-20}"               "$PROPS"
update_property "difficulty"   "${DIFFICULTY:-normal}"             "$PROPS"
update_property "motd"         "${MOTD:-A Gamejanitor Server}"    "$PROPS"
update_property "pvp"          "${PVP:-true}"                     "$PROPS"

echo "[start-server] updated server.properties and eula.txt"

# Calculate JVM heap from MEMORY_LIMIT_MB (leave ~15% for GC overhead)
MEMORY_LIMIT_MB="${MEMORY_LIMIT_MB:-1024}"
HEAP=$(( MEMORY_LIMIT_MB * 85 / 100 ))
if [ "$HEAP" -lt 256 ]; then
    HEAP=256
fi
echo "[start-server] JVM heap: ${HEAP}m (from ${MEMORY_LIMIT_MB}m limit)"

# FIFO pipe for command input
FIFO=/tmp/cmd-input
mkfifo "$FIFO" 2>/dev/null || true

MODLOADER="${MODLOADER:-vanilla}"

# Determine which jar to launch
case "$MODLOADER" in
    fabric)
        SERVER_JAR="/data/fabric-server-launcher.jar"
        ;;
    forge)
        # Modern Forge uses @unix_args.txt with classpath-based launch (no -jar)
        FORGE_ARGS=$(find /data/libraries -name "unix_args.txt" 2>/dev/null | head -1)
        if [ -n "$FORGE_ARGS" ]; then
            # Write our heap settings into user_jvm_args.txt (Forge reads this via @user_jvm_args.txt)
            echo "-Xmx${HEAP}m" > /data/user_jvm_args.txt
            echo "-Xms${HEAP}m" >> /data/user_jvm_args.txt
            echo "[start-server] starting Forge server (modloader=forge, args=$FORGE_ARGS)"
            cd /data
            tail -f "$FIFO" | exec java @user_jvm_args.txt @"$FORGE_ARGS" nogui
            exit 0
        fi
        # Fallback for older Forge versions
        SERVER_JAR=$(find /data -maxdepth 1 -name "forge-*.jar" ! -name "*-installer.jar" ! -name "*-shim.jar" | head -1)
        if [ -z "$SERVER_JAR" ]; then
            SERVER_JAR="/data/server.jar"
        fi
        ;;
    *)
        SERVER_JAR="/data/server.jar"
        ;;
esac

echo "[start-server] starting Minecraft server (modloader=$MODLOADER, jar=$SERVER_JAR)"
tail -f "$FIFO" | exec java -Xmx${HEAP}m -Xms${HEAP}m -jar "$SERVER_JAR" nogui
