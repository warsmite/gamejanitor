#!/bin/bash

FIFO=/tmp/cmd-input

echo "[stop-server] sending save-all"
echo "save-all" > "$FIFO" 2>/dev/null || true
sleep 3

echo "[stop-server] sending stop"
echo "stop" > "$FIFO" 2>/dev/null || true

# Wait for java process to exit (up to 30s)
for i in $(seq 1 30); do
    if ! pgrep -f "server.jar" > /dev/null 2>&1; then
        echo "[stop-server] server stopped gracefully"
        exit 0
    fi
    sleep 1
done

echo "[stop-server] timeout waiting for graceful shutdown, force killing"
pkill -9 -f "server.jar" 2>/dev/null || true
exit 0
