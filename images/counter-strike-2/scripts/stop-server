#!/bin/bash

echo "[stop-server] sending quit via RCON"
/scripts/send-command "quit" 2>/dev/null || true

# Wait for server process to exit (up to 30s)
for i in $(seq 1 30); do
    if ! pgrep -f "cs2" > /dev/null 2>&1; then
        echo "[stop-server] server stopped gracefully"
        exit 0
    fi
    sleep 1
done

echo "[stop-server] timeout waiting for graceful shutdown, force killing"
pkill -9 -f "cs2" 2>/dev/null || true
exit 1
