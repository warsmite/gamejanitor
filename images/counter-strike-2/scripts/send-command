#!/bin/bash
if [ -z "$1" ]; then
    echo "[send-command] usage: send-command <command>"
    exit 1
fi

GAME_PORT="${GAME_PORT:-27015}"
RCON_PASSWORD="${RCON_PASSWORD:-changeme}"

# CS2 binds RCON to the container's IP, not localhost
RCON_HOST=$(hostname -i | awk '{print $1}')
rcon -a "${RCON_HOST}:${GAME_PORT}" -p "$RCON_PASSWORD" "$1"
